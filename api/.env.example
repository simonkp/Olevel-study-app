# Copy to .env and fill in (see README). Never commit .env.

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
MODEL=gpt-4o-mini

# Supabase for JWT verification + Stripe fulfillment writes
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY_PUBLIC=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# Stripe webhook fulfillment (Payment Links + client_reference_id)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_DEFAULT_ENTITLEMENT=olevel_chem

# Admin API key — used to authenticate /admin/* endpoints (POST /admin/link-student, /admin/grant-entitlement)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
ADMIN_API_KEY=

# Comma-separated browser origins allowed for CORS (no spaces). Empty = no CORS middleware.
# Include every dev origin you use (Live Server :5500, Vite/webpack :3000, etc.). Scheme+host+port must match exactly.
CORS_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,http://localhost:3000,http://127.0.0.1:3000

# Optional
# MAX_TOKENS=512
# LLM_TIMEOUT_S=60
